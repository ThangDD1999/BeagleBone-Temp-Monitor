#!/bin/sh
### BEGIN INIT INFO
# Provides:          tempmonitor
# Required-Start:    $network $local_fs
# Required-Stop:     $network $local_fs
# Default-Start:     2 3 4 5
# Default-Stop:      0 1 6
# Description:       IoT Temperature Monitoring System (Server, Collector, Ngrok)
### END INIT INFO

# --- CONFIGURATION ---
APP_DIR="/home/root"
SERVER="/home/root/server"
COLLECTOR="/home/root/collector"
NGROK="/home/root/ngrok"
LOG_FILE="/home/root/ngrok.log"
# Use the config file we generated
CONFIG_FILE="/home/root/.config/ngrok/ngrok.yml"
# Your verified Authtoken
AUTH_TOKEN="3DXTaNtvWmGD2QWj5tyqmPdClqt_mA41QpuMZkbZyMkhS8zE"

case "$1" in
    start)
        echo "Starting Temperature Monitor System..."
        
        # 1. Change to working directory to ensure index.html is found
        cd $APP_DIR || exit 1
        
        # 2. Start Backend Services
        [ -f "$SERVER" ] && $SERVER > /dev/null 2>&1 &
        [ -f "$COLLECTOR" ] && $COLLECTOR > /dev/null 2>&1 &
        echo "  [OK] Server & Collector running in background."

        # 3. Wait for Internet Connection (Critical for Ngrok)
        echo "  -> Checking for internet connectivity..."
        for i in 1 2 3 4 5; do
            if ping -c 1 8.8.8.8 >/dev/null 2>&1; then
                echo "  [OK] Internet connection established!"
                break
            fi
            printf "."
            sleep 5
        done

        # 4. Start Ngrok Tunnel
        if [ -f "$NGROK" ]; then
            echo "  -> Initializing Ngrok tunnel..."
            # Forcing config path and authtoken to prevent ERR_NGROK_4018
            $NGROK http --config=$CONFIG_FILE --authtoken=$AUTH_TOKEN 8080 --log=stdout > "$LOG_FILE" 2>&1 &
            
            # 5. Fetch and Display the Public URL
            printf "  -> Waiting for Public URL ."
            for i in 1 2 3 4 5; do
                sleep 3
                printf "."
                PUBLIC_URL=$(wget -qO- http://127.0.0.1:4040/api/tunnels | grep -o 'https://[^"]*')
                if [ -n "$PUBLIC_URL" ]; then
                    echo -e "\n\n  =================================================="
                    echo -e "  YOUR DASHBOARD IS LIVE AT:"
                    echo -e "  $PUBLIC_URL"
                    echo -e "  ==================================================\n"
                    break
                fi
            done
        fi
        ;;

    stop)
        echo "Stopping services..."
        killall -9 server collector ngrok 2>/dev/null
        echo "Done."
        ;;

    status)
        S_PID=$(pidof server)
        C_PID=$(pidof collector)
        N_PID=$(pidof ngrok)
        [ -n "$S_PID" ] && echo "Server    : [RUNNING]" || echo "Server    : [STOPPED]"
        [ -n "$C_PID" ] && echo "Collector : [RUNNING]" || echo "Collector : [STOPPED]"
        [ -n "$N_PID" ] && echo "Ngrok     : [RUNNING]" || echo "Ngrok     : [STOPPED]"
        ;;

    restart)
        $0 stop
        sleep 2
        $0 start
        ;;

    *)
        echo "Usage: $0 {start|stop|restart|status}"
        exit 1
        ;;
esac

exit 0